<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Catálogo de Produtos Miashop</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,700&family=Outfit:wght@300;400;500;600;700&display=swap');

  :root {
    --ink: #1a1614; --paper: #f4efe6; --card: #fffdf8;
    --br-green: #1b6b3a; --br-yellow: #d9a521; --cn-red: #c8102e;
    --check: #16a34a; --line: #e2dac9; --muted: #8a8073;
    --shadow: 0 8px 30px rgba(26,22,20,0.08);
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    font-family: 'Outfit', sans-serif;
    background:
      radial-gradient(circle at 12% 18%, rgba(217,165,33,0.08), transparent 40%),
      radial-gradient(circle at 88% 82%, rgba(200,16,46,0.06), transparent 45%),
      var(--paper);
    color: var(--ink); min-height: 100vh; padding: 40px 24px 80px;
  }
  .wrap { max-width: 1180px; margin: 0 auto; }
  header { margin-bottom: 22px; display: flex; justify-content: space-between; align-items: flex-start; gap: 20px; flex-wrap: wrap; }
  h1 { font-family: 'Fraunces', serif; font-size: clamp(1.3rem, 3vw, 1.9rem); font-weight: 600; letter-spacing: -0.02em; line-height: 1.05; }
  h1 .accent { font-style: italic; color: var(--cn-red); }
  .subtitle { color: var(--muted); font-size: 1.02rem; margin-top: 8px; max-width: 560px; }

  /* header com logo */
  .header-left { display: flex; align-items: center; gap: 48px; }
  .brand-logo { height: 64px; width: auto; flex-shrink: 0; }
  @media (max-width: 560px){ .brand-logo { height: 46px; } .header-left { gap: 24px; } }

  /* sync pill compacta (só bolinha + engrenagem, sem texto) */
  .sync-pill { display: flex; align-items: center; gap: 8px; background: var(--card); border: 1.5px solid var(--line); padding: 9px 13px; border-radius: 30px; cursor: pointer; font-family: inherit; transition: border-color .2s; }
  .sync-pill:hover { border-color: var(--ink); }
  .sync-dot { width: 10px; height: 10px; border-radius: 50%; background: var(--muted); flex-shrink: 0; }
  .sync-dot.ok { background: var(--check); }
  .sync-dot.off { background: #c0392b; }
  .sync-dot.busy { background: var(--br-yellow); animation: pulse 1s infinite; }
  @keyframes pulse { 50% { opacity: 0.3; } }
  .cfg-gear { font-size: 1rem; color: var(--muted); line-height: 1; }
  .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); border: 0; }

  .tabs { display: flex; gap: 6px; margin: 22px 0 28px; border-bottom: 1.5px solid var(--line); }
  .tab { background: none; border: none; font-family: inherit; font-size: 1rem; font-weight: 600; color: var(--muted); padding: 12px 20px; cursor: pointer; position: relative; transition: color .2s; }
  .tab:hover { color: var(--ink); }
  .tab.active { color: var(--ink); }
  .tab.active::after { content: ''; position: absolute; left: 14px; right: 14px; bottom: -1.5px; height: 3px; background: var(--br-green); border-radius: 3px 3px 0 0; }

  .toolbar { display: flex; gap: 14px; flex-wrap: wrap; align-items: center; margin-bottom: 26px; }
  .search { flex: 1; min-width: 220px; background: var(--card); border: 1.5px solid var(--line); border-radius: 14px; padding: 13px 18px; font-family: inherit; font-size: 0.98rem; color: var(--ink); transition: border-color .2s, box-shadow .2s; }
  .search:focus { outline: none; border-color: var(--br-green); box-shadow: 0 0 0 4px rgba(27,107,58,0.1); }

  .btn { border: none; border-radius: 14px; padding: 13px 24px; font-family: inherit; font-size: 0.98rem; font-weight: 600; cursor: pointer; transition: transform .15s, box-shadow .2s; display: inline-flex; align-items: center; gap: 8px; }
  .btn:active { transform: scale(0.97); }
  .btn-primary { background: var(--ink); color: var(--paper); box-shadow: var(--shadow); }
  .btn-primary:hover { box-shadow: 0 10px 36px rgba(26,22,20,0.18); }
  .btn-ghost { background: transparent; border: 1.5px solid var(--line); color: var(--ink); }
  .btn-ghost:hover { border-color: var(--ink); }

  .form-card { background: var(--card); border: 1.5px solid var(--line); border-radius: 22px; padding: 28px; margin-bottom: 36px; box-shadow: var(--shadow); display: none; }
  .form-card.open { display: block; animation: slideIn .3s ease; }
  @keyframes slideIn { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }
  .form-grid { display: grid; grid-template-columns: 280px 1fr; gap: 28px; }
  @media (max-width: 720px) { .form-grid { grid-template-columns: 1fr; } }

  .dropzone { border: 2.5px dashed var(--line); border-radius: 18px; aspect-ratio: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 12px; cursor: pointer; text-align: center; padding: 20px; background: rgba(255,253,248,0.5); transition: border-color .2s, background .2s; overflow: hidden; position: relative; }
  .dropzone:hover, .dropzone.dragover { border-color: var(--br-green); background: rgba(27,107,58,0.05); }
  .dropzone img { width: 100%; height: 100%; object-fit: cover; border-radius: 14px; position: absolute; inset: 0; }
  .dropzone .icon { font-size: 2.4rem; }
  .dropzone .dz-text { color: var(--muted); font-size: 0.9rem; line-height: 1.4; }

  .fields { display: flex; flex-direction: column; gap: 16px; }
  .field label { display: block; font-size: 0.82rem; font-weight: 600; color: var(--muted); margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.04em; }
  .field input, .field textarea, .field select { width: 100%; background: var(--paper); border: 1.5px solid var(--line); border-radius: 12px; padding: 12px 14px; font-family: inherit; font-size: 0.98rem; color: var(--ink); transition: border-color .2s; }
  .field input:focus, .field textarea:focus, .field select:focus { outline: none; border-color: var(--br-green); }
  .field textarea { resize: vertical; min-height: 70px; line-height: 1.4; }
  .row-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .price-input { position: relative; }
  .price-input .flag { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); font-size: 1.1rem; }
  .price-input input { padding-left: 40px; }
  .price-input.br input:focus { border-color: var(--br-green); }
  .price-input.cn input:focus { border-color: var(--cn-red); }
  .price-input.cg input:focus { border-color: #2563eb; }
  .form-actions { display: flex; gap: 12px; margin-top: 8px; }

  .stats { display: flex; gap: 28px; margin-bottom: 22px; flex-wrap: wrap; }
  .stat { font-size: 0.92rem; color: var(--muted); }
  .stat b { color: var(--ink); font-family: 'Fraunces', serif; font-size: 1.3rem; font-weight: 600; }

  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(270px, 1fr)); gap: 22px; }
  .product { background: var(--card); border: 1.5px solid var(--line); border-radius: 20px; overflow: hidden; box-shadow: var(--shadow); transition: transform .2s, box-shadow .2s; display: flex; flex-direction: column; }
  .product:hover { transform: translateY(-4px); box-shadow: 0 14px 40px rgba(26,22,20,0.13); }
  .product .photo { aspect-ratio: 4/3; background: var(--paper); position: relative; overflow: hidden; }
  .product .photo img { width: 100%; height: 100%; object-fit: cover; }
  .product .photo .no-img { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 2rem; color: var(--line); }
  .product .cat { position: absolute; top: 12px; left: 12px; background: rgba(26,22,20,0.85); color: var(--paper); font-size: 0.72rem; font-weight: 600; padding: 5px 11px; border-radius: 20px; text-transform: uppercase; letter-spacing: 0.04em; backdrop-filter: blur(4px); }
  .product.checked .photo::after { content: '✓'; position: absolute; top: 12px; right: 12px; width: 30px; height: 30px; background: var(--check); color: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; box-shadow: 0 4px 12px rgba(22,163,74,0.4); }
  .product .body { padding: 18px; flex: 1; display: flex; flex-direction: column; }
  .product h3 { font-family: 'Fraunces', serif; font-size: 1.2rem; font-weight: 600; margin-bottom: 6px; line-height: 1.2; }
  .product .card-obs { font-size: 0.85rem; color: var(--muted); background: rgba(26,22,20,0.04); border-radius: 10px; padding: 8px 11px; margin-bottom: 12px; line-height: 1.4; }
  .prices { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin: 6px 0 14px; }
  .price-box { border-radius: 12px; padding: 11px 13px; }
  .price-box.br { background: rgba(27,107,58,0.09); }
  .price-box.cn { background: rgba(200,16,46,0.08); }
  .price-box .plabel { font-size: 0.72rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.03em; margin-bottom: 3px; }
  .price-box.br .plabel { color: var(--br-green); }
  .price-box.cn .plabel { color: var(--cn-red); }
  .price-box .pval { font-family: 'Fraunces', serif; font-size: 1.15rem; font-weight: 600; }
  .price-box.cg { background: rgba(37,99,235,0.09); }
  .price-box.cg .plabel { color: #2563eb; }
  .price-box.tax-box { background: rgba(184,134,11,0.12); }
  .price-box.tax-box .plabel { color: #b8860b; }
  .card-actions { display: flex; gap: 8px; }
  .mini-btn { flex: 1; border: 1.5px solid var(--line); background: transparent; border-radius: 10px; padding: 8px; font-family: inherit; font-size: 0.85rem; cursor: pointer; color: var(--muted); transition: all .15s; }
  .mini-btn:hover { border-color: var(--ink); color: var(--ink); }
  .mini-btn.del:hover { border-color: var(--cn-red); color: var(--cn-red); }

  .filters { display: flex; gap: 12px; flex-wrap: wrap; align-items: center; margin-bottom: 20px; }
  .filters .search { flex: 1; min-width: 200px; }
  .filters select { background: var(--card); border: 1.5px solid var(--line); border-radius: 14px; padding: 13px 16px; font-family: inherit; font-size: 0.95rem; color: var(--ink); cursor: pointer; }
  .filters select:focus { outline: none; border-color: var(--br-green); }

  .list { background: var(--card); border: 1.5px solid var(--line); border-radius: 18px; box-shadow: var(--shadow); overflow-x: auto; }
  .list-head, .list-row, .list-foot { display: grid; grid-template-columns: 32px 44px minmax(130px,1fr) 92px 50px 84px 84px 92px 84px 92px 110px 64px; align-items: center; gap: 7px; padding: 13px 14px; min-width: 1140px; }
  .list-head { background: rgba(26,22,20,0.04); font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; color: var(--muted); border-bottom: 1.5px solid var(--line); }
  .list-row { border-bottom: 1px solid var(--line); transition: background .15s; }
  .list-row:last-child { border-bottom: none; }
  .list-row:hover { background: rgba(27,107,58,0.03); }
  .list-row.checked { background: rgba(22,163,74,0.06); }
  .list-row .lthumb { width: 48px; height: 48px; border-radius: 10px; object-fit: cover; background: var(--paper); cursor: zoom-in; transition: transform .15s; }
  .list-row .lthumb:hover { transform: scale(1.08); }
  .list-row .lthumb-empty { width: 48px; height: 48px; border-radius: 10px; background: var(--paper); display: flex; align-items: center; justify-content: center; color: var(--line); }
  .list-row .lname { font-weight: 600; }
  .list-row .lobs { display: block; font-weight: 400; font-size: 0.8rem; color: var(--muted); margin-top: 3px; line-height: 1.35; }
  .lcat { font-size: 0.85rem; color: var(--muted); }
  .lprice { font-family: 'Fraunces', serif; font-weight: 600; font-size: 1rem; }
  .lprice.br { color: var(--br-green); }
  .lprice.cn { color: var(--cn-red); }
  .lprice.cg { color: #2563eb; }
  .lprice.cgtax { color: #2563eb; }
  .lprice.tax { color: var(--cn-red); }
  .lprice.total { color: var(--ink); font-weight: 700; }
  .list-foot .lprice.total { color: var(--br-green); font-size: 1.1rem; }
  .lprice small { display: block; font-family: 'Outfit', sans-serif; font-weight: 400; font-size: 0.66rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.03em; }

  /* Lightbox foto */
  .lightbox { position: fixed; inset: 0; background: rgba(26,22,20,0.85); backdrop-filter: blur(4px); display: none; align-items: center; justify-content: center; z-index: 200; padding: 30px; cursor: zoom-out; }
  .lightbox.open { display: flex; animation: fadeIn .2s ease; }
  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
  .lightbox img { max-width: 90vw; max-height: 88vh; border-radius: 16px; box-shadow: 0 20px 70px rgba(0,0,0,0.5); animation: zoomIn .2s ease; }
  @keyframes zoomIn { from { transform: scale(0.92); opacity: 0; } to { transform: scale(1); opacity: 1; } }
  .lightbox .lb-cap { position: absolute; bottom: 24px; left: 0; right: 0; text-align: center; color: #fff; font-family: 'Fraunces', serif; font-size: 1.1rem; }
  .check { width: 30px; height: 30px; border-radius: 8px; border: 2px solid var(--line); background: var(--paper); cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 1rem; color: transparent; transition: all .15s; }
  .check:hover { border-color: var(--check); }
  .check.on { background: var(--check); border-color: var(--check); color: #fff; }
  .lqtd { font-weight: 600; text-align: center; font-size: 0.95rem; }
  .lacts { display: flex; gap: 4px; justify-content: flex-end; }
  .lact { background: none; border: none; cursor: pointer; color: var(--muted); font-size: 1rem; padding: 5px; border-radius: 8px; transition: all .15s; line-height: 1; }
  .lact.edit:hover { color: var(--br-green); background: rgba(27,107,58,0.1); }
  .lact.del:hover { color: var(--cn-red); background: rgba(200,16,46,0.08); }
  /* compat antigo */
  .ldel { background: none; border: none; cursor: pointer; color: var(--muted); font-size: 1.05rem; padding: 6px; border-radius: 8px; transition: all .15s; }
  .ldel:hover { color: var(--cn-red); background: rgba(200,16,46,0.08); }

  .list-foot { border-top: 2px solid var(--line); background: rgba(26,22,20,0.03); font-weight: 700; }
  .list-foot .ftotal-label { grid-column: 1 / 5; font-family: 'Fraunces', serif; font-size: 0.95rem; }
  .list-foot .lqtd { font-family: 'Fraunces', serif; }
  .list-foot .lprice { font-family: 'Fraunces', serif; font-size: 1rem; }
  .list-foot .lprice small { display: block; font-family: 'Outfit',sans-serif; font-weight: 400; font-size: 0.62rem; color: var(--muted); text-transform: uppercase; }

  .empty { text-align: center; padding: 80px 20px; color: var(--muted); }
  .empty .icon { font-size: 3rem; margin-bottom: 14px; }
  .loading { text-align: center; padding: 60px; color: var(--muted); }

  /* Modal */
  .modal-bg { position: fixed; inset: 0; background: rgba(26,22,20,0.5); backdrop-filter: blur(3px); display: none; align-items: center; justify-content: center; padding: 20px; z-index: 100; }
  .modal-bg.open { display: flex; }
  .modal { background: var(--card); border-radius: 22px; padding: 32px; max-width: 540px; width: 100%; box-shadow: 0 20px 60px rgba(0,0,0,0.3); max-height: 90vh; overflow-y: auto; }
  .modal h2 { font-family: 'Fraunces', serif; font-size: 1.5rem; margin-bottom: 6px; }
  .modal p.lead { color: var(--muted); font-size: 0.92rem; margin-bottom: 20px; line-height: 1.5; }
  .modal .field { margin-bottom: 16px; }
  .modal .help { font-size: 0.82rem; color: var(--muted); margin-top: 6px; line-height: 1.45; }
  .modal .help a { color: var(--br-green); }
  .modal .warn { background: rgba(217,165,33,0.13); border: 1.5px solid rgba(217,165,33,0.4); border-radius: 12px; padding: 13px 15px; font-size: 0.85rem; line-height: 1.5; margin-bottom: 18px; color: #7a5e10; }
  .modal-actions { display: flex; gap: 12px; margin-top: 8px; }
  details.steps { margin-bottom: 18px; }
  details.steps summary { cursor: pointer; font-weight: 600; color: var(--br-green); font-size: 0.9rem; }
  details.steps ol { margin: 12px 0 0 18px; font-size: 0.86rem; color: var(--muted); line-height: 1.7; }
  code { background: rgba(26,22,20,0.07); padding: 1px 6px; border-radius: 5px; font-size: 0.85em; }
</style>
</head>
<body>
<div class="wrap">
  <header>
    <div class="header-left">
      <img class="brand-logo" src="data:image/png;base64," alt="MiaShop">
      <div>
        <h1>Catálogo de <span class="accent">Produtos</span></h1>
      </div>
    </div>
    <button class="sync-pill" id="openCfg" title="Sincronização">
      <span class="sync-dot" id="syncDot"></span>
      <span id="syncText" class="sr-only"></span>
      <span class="cfg-gear">⚙</span>
    </button>
  </header>

  <div class="tabs">
    <button class="tab active" data-tab="catalogo">＋ Incluir Produto</button>
    <button class="tab" data-tab="lista">📋 Lista</button>
  </div>

  <!-- INCLUIR PRODUTO -->
  <div id="tab-catalogo">
    <div class="form-card open" id="formCard">
      <div class="form-grid">
        <div class="dropzone" id="dropzone">
          <input type="file" id="fileInput" accept="image/*" hidden>
          <span class="icon">📷</span>
          <span class="dz-text">Arraste a foto aqui<br>ou clique para selecionar</span>
        </div>
        <div class="fields">
          <div class="field"><label>Descrição / Nome</label><input id="f-desc" placeholder="Ex.: Fone de ouvido bluetooth"></div>
          <div class="row-2">
            <div class="field"><label>Categoria</label><input id="f-cat" list="cats" placeholder="Ex.: Eletrônicos"><datalist id="cats"></datalist></div>
            <div class="field"><label>Quantidade</label><input id="f-qtd" type="number" step="1" min="0" placeholder="0"></div>
          </div>
          <div class="row-2">
            <div class="field"><label>Valor no Brasil</label><div class="price-input br"><span class="flag">🇧🇷</span><input id="f-br" type="number" step="0.01" placeholder="R$ 0,00"></div></div>
            <div class="field"><label>Valor ChinaGoods</label><div class="price-input cg"><span class="flag">🛒</span><input id="f-cg" type="number" step="0.01" placeholder="¥ 0,00"></div></div>
          </div>
          <div class="row-2">
            <div class="field"><label>Valor na China</label><div class="price-input cn"><span class="flag">🇨🇳</span><input id="f-cn" type="number" step="0.01" placeholder="¥ 0,00"></div></div>
            <div class="field"></div>
          </div>
          <div class="field"><label>Observações</label><textarea id="f-obs" placeholder="Anotações sobre o produto, fornecedor, prazo, etc."></textarea></div>
          <div class="form-actions">
            <button class="btn btn-primary" id="saveBtn">Salvar e ir para a lista</button>
            <button class="btn btn-ghost" id="cancelBtn">Limpar</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- LISTA -->
  <div id="tab-lista" style="display:none">
    <div class="filters">
      <input class="search" id="l-search" placeholder="Filtrar por nome...">
      <select id="l-cat"><option value="">Todas as categorias</option></select>
      <select id="l-check">
        <option value="all">Com e sem check</option>
        <option value="checked">✓ Apenas com check</option>
        <option value="unchecked">○ Apenas sem check</option>
      </select>
    </div>
    <div class="stats" id="l-stats"></div>
    <div id="l-content"></div>
  </div>
</div>

<!-- LIGHTBOX -->
<div class="lightbox" id="lightbox"><img id="lbImg" src=""><div class="lb-cap" id="lbCap"></div></div>

<!-- MODAL CONFIG APPS SCRIPT -->
<div class="modal-bg" id="cfgModal">
  <div class="modal">
    <h2>Sincronização com Google Sheets</h2>
    <p class="lead">Cole a URL do seu Web App (Apps Script) para salvar tudo automaticamente na planilha e nas fotos no Drive, acessível de qualquer computador.</p>
    <div class="warn"><b>Como obter a URL:</b> siga o passo a passo abaixo no seu Google Sheets. A URL e o token ficam salvos apenas neste navegador.</div>
    <details class="steps">
      <summary>Passo a passo para conectar (clique para ver)</summary>
      <ol>
        <li>Crie uma planilha nova no <a href="https://sheets.new" target="_blank">Google Sheets</a>.</li>
        <li>No menu, vá em <b>Extensões → Apps Script</b>.</li>
        <li>Apague o conteúdo e cole todo o código do arquivo <code>Code.gs</code>.</li>
        <li>Clique no disquete (Salvar).</li>
        <li>Clique em <b>Implantar → Nova implantação</b>.</li>
        <li>Em "Selecionar tipo" (engrenagem), escolha <b>App da Web</b>.</li>
        <li>Em <b>Executar como</b>: Eu mesmo. Em <b>Quem pode acessar</b>: <b>Qualquer pessoa</b>.</li>
        <li>Clique <b>Implantar</b> e <b>autorize</b> o acesso (sua conta Google).</li>
        <li>Copie a <b>URL do app da Web</b> (termina em <code>/exec</code>) e cole abaixo.</li>
        <li>(Opcional) Para um token, no editor vá em <b>Configurações do projeto → Propriedades do script</b>, adicione <code>TOKEN</code> com um valor secreto e use o mesmo aqui.</li>
      </ol>
    </details>
    <div class="field"><label>URL do Web App (termina em /exec)</label><input id="cfg-url" placeholder="https://script.google.com/macros/s/.../exec"></div>
    <div class="field"><label>Token (opcional)</label><input id="cfg-token" type="password" placeholder="deixe vazio se não definiu"><div class="help">Só preencha se você adicionou a propriedade TOKEN no Apps Script.</div></div>
    <div class="modal-actions">
      <button class="btn btn-primary" id="cfg-save">Conectar e sincronizar</button>
      <button class="btn btn-ghost" id="cfg-disconnect">Desconectar</button>
      <button class="btn btn-ghost" id="cfg-close">Fechar</button>
    </div>
  </div>
</div>

<script>
const $ = s => document.querySelector(s);
let products = [];
let editingId = null, pendingImage = null;
let cfg = null;        // {url, token}

// URL do Web App (Apps Script) embutida como padrão.
// Para trocar, use a engrenagem ⚙ no sistema ou edite a linha abaixo.
const URL_PADRAO = 'https://script.google.com/macros/s/AKfycbz89TLwHeIE__SB2VReZojnPAownPehj-h9mF7-LRFTqENP_KxQajW6yRFtAQAZYz_3/exec';

// ============ Persistência local (config + cache) ============
async function lset(k,v){ try{ await window.storage.set(k, JSON.stringify(v)); }catch(e){} }
async function lget(k){ try{ const r=await window.storage.get(k); return r?JSON.parse(r.value):null; }catch(e){ return null; } }
async function ldel(k){ try{ await window.storage.delete(k); }catch(e){} }

// ============ Apps Script (Google Sheets) API ============
// Carrega todos os produtos da planilha
async function gsLoad(){
  const res = await fetch(cfg.url, { method:'GET' });
  if (!res.ok) throw new Error('HTTP '+res.status);
  const data = await res.json();
  if (!data.ok) throw new Error(data.erro || 'Falha na leitura');
  return Array.isArray(data.produtos) ? data.produtos : [];
}

// Envia uma ação de escrita. Usa text/plain p/ evitar preflight CORS do Apps Script.
async function gsPost(payload){
  payload.token = cfg.token || '';
  const res = await fetch(cfg.url, {
    method: 'POST',
    headers: { 'Content-Type': 'text/plain;charset=utf-8' },
    body: JSON.stringify(payload),
    redirect: 'follow'
  });
  if (!res.ok) throw new Error('HTTP '+res.status);
  const data = await res.json();
  if (!data.ok) throw new Error(data.erro || 'Falha na gravação');
  return data;
}

// Fila de gravação: garante ordem e evita corridas
let queue = Promise.resolve();
function enqueue(task){
  queue = queue.then(async () => {
    if (!cfg){ setSync('local'); return; }
    setSync('busy');
    try { await task(); setSync('ok'); }
    catch(e){ setSync('error', e.message); }
  });
  return queue;
}

// Ações específicas (gravação granular — não reescreve tudo)
function persistSave(p){ return enqueue(()=>gsPost({ acao:'salvar', produto:p })); }
function persistDelete(id){ return enqueue(()=>gsPost({ acao:'excluir', id })); }
function persistCheck(id, checked){ return enqueue(()=>gsPost({ acao:'check', id, checked })); }

// ============ Sync status UI ============
function setSync(state, msg){
  const dot = $('#syncDot'), pill = $('#openCfg');
  dot.className = 'sync-dot';
  let tip;
  if (state==='ok'){ dot.classList.add('ok'); tip = 'Sincronizado com o Google Sheets'; }
  else if (state==='busy'){ dot.classList.add('busy'); tip = 'Salvando...'; }
  else if (state==='error'){ dot.classList.add('off'); tip = 'Erro ao salvar — clique para configurar'; if(msg) console.warn('Sync:', msg); }
  else if (state==='off'){ dot.classList.add('off'); tip = 'Desconectado — clique para configurar'; }
  else { tip = 'Não sincronizado — clique para configurar'; }
  if (pill) pill.title = tip;
}

// ============ Image ============
function handleFile(file){
  if (!file || !file.type.startsWith('image/')) return;
  const reader = new FileReader();
  reader.onload = e => resizeImage(e.target.result, 700, dataUrl => {
    pendingImage = dataUrl;
    const dz = $('#dropzone'); dz.querySelector('img')?.remove();
    const img = document.createElement('img'); img.src = dataUrl; dz.appendChild(img);
  });
  reader.readAsDataURL(file);
}
function resizeImage(src, maxW, cb){
  const img = new Image();
  img.onload = () => {
    const scale = Math.min(1, maxW / img.width);
    const c = document.createElement('canvas');
    c.width = img.width*scale; c.height = img.height*scale;
    c.getContext('2d').drawImage(img,0,0,c.width,c.height);
    cb(c.toDataURL('image/jpeg', 0.78));
  };
  img.src = src;
}

// ============ Form ============
function loadForm(p){
  const dz = $('#dropzone'); dz.querySelector('img')?.remove();
  if (p){
    editingId = p.id;
    $('#f-desc').value=p.desc; $('#f-cat').value=p.cat;
    $('#f-br').value=p.br??''; $('#f-cn').value=p.cn??'';
    $('#f-cg').value=p.cg??'';
    $('#f-obs').value=p.obs||'';
    $('#f-qtd').value=p.qtd??'';
    pendingImage = p.image;
    if (p.image){ const img=document.createElement('img'); img.src=p.image; dz.appendChild(img); }
    $('#saveBtn').textContent = 'Salvar alterações';
  } else {
    editingId=null; pendingImage=null;
    $('#f-desc').value=''; $('#f-cat').value=''; $('#f-br').value=''; $('#f-cn').value=''; $('#f-cg').value=''; $('#f-obs').value=''; $('#f-qtd').value='';
    $('#saveBtn').textContent = 'Salvar e ir para a lista';
  }
  $('#f-desc').focus();
}
function clearForm(){ loadForm(null); }

async function save(){
  const desc = $('#f-desc').value.trim();
  if (!desc){ $('#f-desc').focus(); return; }
  const existing = products.find(x=>x.id===editingId);
  const p = {
    id: editingId || (Date.now()+''+Math.random().toString(36).slice(2,6)),
    desc, cat: $('#f-cat').value.trim() || 'Sem categoria',
    br: $('#f-br').value ? parseFloat($('#f-br').value) : null,
    cg: $('#f-cg').value ? parseFloat($('#f-cg').value) : null,
    cn: $('#f-cn').value ? parseFloat($('#f-cn').value) : null,
    obs: $('#f-obs').value.trim(),
    qtd: $('#f-qtd').value ? parseInt($('#f-qtd').value) : null,
    image: pendingImage,
    checked: existing ? !!existing.checked : false,
    created: existing ? existing.created : Date.now()
  };
  const i = products.findIndex(x=>x.id===p.id);
  if (i>=0) products[i]=p; else products.unshift(p);
  clearForm();
  renderLista();
  switchTab('lista');           // após salvar, vai direto para a Lista
  window.scrollTo({top:0,behavior:'smooth'});
  lset('cache', products);
  persistSave(p);
}

// ============ Helpers ============
function fmt(v,cur){ if(v==null) return '—'; return (cur==='br'?'R$ ':'¥ ')+v.toLocaleString('pt-BR',{minimumFractionDigits:2,maximumFractionDigits:2}); }
function esc(s){ return (s||'').replace(/[&<>"]/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c])); }

// ============ Datalist de categorias (autocomplete do form) ============
function updateCats(){
  const cats = [...new Set(products.map(p=>p.cat))];
  $('#cats').innerHTML = cats.map(c=>`<option value="${esc(c)}">`).join('');
}

// ============ Render Lista ============
function renderLista(){
  const cats = [...new Set(products.map(p=>p.cat))].sort();
  const sel = $('#l-cat'), cur = sel.value;
  sel.innerHTML = '<option value="">Todas as categorias</option>'+cats.map(c=>`<option value="${esc(c)}">${esc(c)}</option>`).join('');
  if (cats.includes(cur)) sel.value = cur;
  const q = $('#l-search').value.toLowerCase().trim();
  const fcat = $('#l-cat').value, fchk = $('#l-check').value;
  const list = products.filter(p=>{
    if (q && !p.desc.toLowerCase().includes(q) && !(p.obs||'').toLowerCase().includes(q)) return false;
    if (fcat && p.cat!==fcat) return false;
    if (fchk==='checked' && !p.checked) return false;
    if (fchk==='unchecked' && p.checked) return false;
    return true;
  });
  const done = products.filter(p=>p.checked).length;
  $('#l-stats').innerHTML = `<span class="stat"><b>${list.length}</b> exibidos</span><span class="stat"><b>${done}</b> com check</span><span class="stat"><b>${products.length-done}</b> sem check</span>`;
  const c = $('#l-content');
  if (!list.length){ c.innerHTML = `<div class="empty"><div class="icon">📋</div><p>Nenhum produto encontrado com esses filtros.</p></div>`; return; }

  // totais: Valor Total por produto = qtd × (China + Impostos). Demais colunas somam preço × qtd.
  const tot = { qtd:0, br:0, cg:0, cgtax:0, cn:0, cntax:0, total:0 };
  list.forEach(p=>{
    const q = p.qtd != null && p.qtd > 0 ? p.qtd : 1;
    if (p.qtd != null) tot.qtd += p.qtd;
    if (p.br != null) tot.br += p.br * q;
    if (p.cg != null){ tot.cg += p.cg * q; tot.cgtax += p.cg * 1.30 * q; }
    if (p.cn != null){ tot.cn += p.cn * q; tot.cntax += p.cn * 1.30 * q; }
    if (p.cn != null && p.qtd != null) tot.total += p.cn * 1.30 * p.qtd;  // valor total real
  });

  c.innerHTML = `<div class="list">
    <div class="list-head"><span>✓</span><span>Foto</span><span>Produto</span><span>Categoria</span><span>Qtd</span><span>🇧🇷 Brasil</span><span>🛒 ChinaGoods</span><span>🛒 + Impostos</span><span>🇨🇳 China</span><span>🇨🇳 + Impostos</span><span>💰 Valor Total</span><span></span></div>
    ${list.map(row).join('')}
    <div class="list-foot">
      <span class="ftotal-label">TOTAL (${list.length} ${list.length===1?'item':'itens'})</span>
      <span class="lqtd">${tot.qtd||'—'}</span>
      <span class="lprice br">${fmt(tot.br,'br')}</span>
      <span class="lprice cg">${fmt(tot.cg,'cn')}</span>
      <span class="lprice cgtax">${fmt(tot.cgtax,'br')}</span>
      <span class="lprice cn">${fmt(tot.cn,'cn')}</span>
      <span class="lprice tax">${fmt(tot.cntax,'br')}</span>
      <span class="lprice total">${fmt(tot.total,'br')}</span>
      <span></span>
    </div>
  </div>`;
}
function row(p){
  const cnTax = p.cn != null ? p.cn * 1.30 : null;
  const cgTax = p.cg != null ? p.cg * 1.30 : null;
  const valorTotal = (p.cn != null && p.qtd != null) ? p.cn * 1.30 * p.qtd : null;
  return `<div class="list-row ${p.checked?'checked':''}">
    <div class="check ${p.checked?'on':''}" onclick="toggleCheck('${p.id}')" title="Marcar/desmarcar">✓</div>
    ${p.image?`<img class="lthumb" src="${p.image}" onclick="zoom('${p.id}')" title="Clique para ampliar">`:`<div class="lthumb-empty">📷</div>`}
    <div class="lname">${esc(p.desc)}${p.obs?`<small class="lobs">📝 ${esc(p.obs)}</small>`:''}</div>
    <div class="lcat">${esc(p.cat)}</div>
    <div class="lqtd">${p.qtd != null ? p.qtd : '—'}</div>
    <div class="lprice br">${fmt(p.br,'br')}</div>
    <div class="lprice cg">${fmt(p.cg,'cn')}</div>
    <div class="lprice cgtax">${fmt(cgTax,'br')}<small>+30%</small></div>
    <div class="lprice cn">${fmt(p.cn,'cn')}</div>
    <div class="lprice tax">${fmt(cnTax,'br')}<small>+30%</small></div>
    <div class="lprice total">${fmt(valorTotal,'br')}${valorTotal!=null?`<small>${p.qtd}× c/imp.</small>`:''}</div>
    <div class="lacts">
      <button class="lact edit" onclick="edit('${p.id}')" title="Editar">✎</button>
      <button class="lact del" onclick="remove('${p.id}')" title="Excluir">🗑</button>
    </div>
  </div>`;
}

function renderAll(){ updateCats(); renderLista(); }

// ============ Actions ============
window.edit = id => { const p=products.find(x=>x.id===id); if(p){ switchTab('catalogo'); loadForm(p); window.scrollTo({top:0,behavior:'smooth'}); } };
window.remove = async id => {
  if (!confirm('Excluir este produto?')) return;
  products = products.filter(x=>x.id!==id);
  renderAll(); lset('cache', products); persistDelete(id);
};
window.toggleCheck = async id => {
  const p = products.find(x=>x.id===id); if(!p) return;
  p.checked = !p.checked; renderAll(); lset('cache', products); persistCheck(id, p.checked);
};
window.zoom = id => {
  const p = products.find(x=>x.id===id); if(!p||!p.image) return;
  $('#lbImg').src = p.image;
  $('#lbCap').textContent = p.desc;
  $('#lightbox').classList.add('open');
};
$('#lightbox').onclick = () => $('#lightbox').classList.remove('open');
document.addEventListener('keydown', e => { if(e.key==='Escape') $('#lightbox').classList.remove('open'); });

// ============ Tabs ============
function switchTab(name){
  document.querySelectorAll('.tab').forEach(t=>t.classList.toggle('active', t.dataset.tab===name));
  $('#tab-catalogo').style.display = name==='catalogo'?'block':'none';
  $('#tab-lista').style.display = name==='lista'?'block':'none';
}
document.querySelectorAll('.tab').forEach(t=>t.onclick=()=>switchTab(t.dataset.tab));

// ============ Config modal ============
function openCfg(){
  $('#cfgModal').classList.add('open');
  if (cfg){ $('#cfg-url').value=cfg.url; $('#cfg-token').value=cfg.token||''; }
}
function closeCfg(){ $('#cfgModal').classList.remove('open'); }

$('#openCfg').onclick = openCfg;
$('#cfg-close').onclick = closeCfg;
$('#cfg-save').onclick = async () => {
  const url = $('#cfg-url').value.trim();
  const token = $('#cfg-token').value.trim();
  if (!url){ alert('Cole a URL do Web App (termina em /exec).'); return; }
  if (!/\/exec$/.test(url)){ if(!confirm('A URL normalmente termina em /exec. Continuar mesmo assim?')) return; }
  cfg = { url, token };
  setSync('busy');
  try {
    const remoteList = await gsLoad();       // testa conexão + carrega da planilha
    products = remoteList;
    products.sort((a,b)=>b.created-a.created);
    await lset('cfg', cfg);
    await lset('cache', products);
    setSync('ok'); closeCfg(); renderAll();
  } catch(e){
    cfg = null;
    setSync('error', e.message);
    alert('Não consegui conectar.\n\nVerifique se:\n• a URL termina em /exec\n• a implantação está como "Qualquer pessoa"\n• o código Code.gs foi colado e salvo\n\nDetalhe: '+e.message);
  }
};
$('#cfg-disconnect').onclick = async () => {
  cfg = null;
  await ldel('cfg');
  setSync('off'); closeCfg();
};

// ============ Events ============
$('#cancelBtn').onclick = clearForm;
$('#saveBtn').onclick = save;
$('#l-search').oninput = renderLista;
$('#l-cat').onchange = renderLista;
$('#l-check').onchange = renderLista;

const dz=$('#dropzone'), fi=$('#fileInput');
dz.onclick=()=>fi.click();
fi.onchange=e=>handleFile(e.target.files[0]);
dz.addEventListener('dragover',e=>{e.preventDefault();dz.classList.add('dragover');});
dz.addEventListener('dragleave',()=>dz.classList.remove('dragover'));
dz.addEventListener('drop',e=>{e.preventDefault();dz.classList.remove('dragover');handleFile(e.dataTransfer.files[0]);});
document.addEventListener('paste',e=>{ if($('#tab-catalogo').style.display==='none')return; const item=[...e.clipboardData.items].find(i=>i.type.startsWith('image/')); if(item)handleFile(item.getAsFile()); });

// ============ Init ============
(async () => {
  cfg = await lget('cfg');
  // se não há config salva mas existe URL embutida, usa-a automaticamente
  if (!cfg && URL_PADRAO) cfg = { url: URL_PADRAO, token: '' };
  if (cfg){
    setSync('busy');
    try {
      products = await gsLoad();
      await lset('cache', products);
      setSync('ok');
    } catch(e){
      // offline ou erro: usa cache local
      products = await lget('cache') || [];
      setSync('error', e.message);
    }
  } else {
    products = await lget('cache') || [];
    setSync('local');
  }
  products.sort((a,b)=>b.created-a.created);
  renderAll();
})();
</script>
</body>
</html>
